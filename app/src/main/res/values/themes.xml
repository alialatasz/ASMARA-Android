<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ASMARA" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_orange</item>
        <item name="colorSecondaryVariant">@color/accent_orange</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/off_white</item>
        <item name="android:fontFamily">@font/lexend</item>
        <item name="fontFamily">@font/lexend</item>
    </style>

    <style name="Theme.ASMARA.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/primary_dark</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.ASMARA.NoActionBar" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>

    <style name="Theme.ASMARA.Camera" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:statusBarColor">@color/camera_bg</item>
        <item name="android:windowBackground">@color/camera_bg</item>
    </style>



    <!-- Button Styles -->
    <style name="Button.ASMARA.AR" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/ar_button</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">30dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="elevation">8dp</item>
    </style>

    <style name="Button.ASMARA.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <!-- Text Styles -->
    <style name="Text.ASMARA.Title" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.ASMARA.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/text_medium</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.Corner.Size50Percent" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
