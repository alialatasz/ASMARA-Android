<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pattern_tiled"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical">

        <!-- Header Container -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Background Gradient -->
            <View
                android:id="@+id/bg_header"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="@drawable/bg_welcome_gradient"
                app:layout_constraintTop_toTopOf="parent" />
                
            <!-- Watermark Logo ASMARA -->
            <ImageView
                android:layout_width="450dp"
                android:layout_height="450dp"
                android:src="@drawable/logo_asmara"
                app:tint="#FFFFFF"
                android:alpha="0.12"
                android:scaleType="centerCrop"
                app:layout_constraintBottom_toBottomOf="@+id/bg_header"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="-20dp"
                android:layout_marginBottom="-85dp" />

            <!-- Tombol Kembali -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btn_back_profil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                android:src="@drawable/ic_close"
                android:contentDescription="Kembali"
                app:backgroundTint="#33FFFFFF"
                app:tint="@color/white"
                app:fabSize="mini"
                app:elevation="4dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- Judul -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profil Saya"
                android:textColor="#DDFFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp"/>

            <!-- Nama Panggilan (Muncul setelah disimpan) -->
            <TextView
                android:id="@+id/tv_display_nama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Halo, Penjelajah!"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/lexend"
                app:layout_constraintBottom_toTopOf="@id/fl_avatar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="16dp"/>

            <!-- Avatar Circle -->
            <FrameLayout
                android:id="@+id/fl_avatar"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:background="@drawable/circle_white"
                android:elevation="8dp"
                app:layout_constraintTop_toBottomOf="@id/bg_header"
                app:layout_constraintBottom_toBottomOf="@id/bg_header"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tv_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🦊"
                    android:textSize="52sp"
                    android:gravity="center"/>
                    
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_avatar_photo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner.Size50Percent" />
            </FrameLayout>

            <!-- Tombol Ganti Avatar -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btn_ganti_avatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_gallery"
                android:contentDescription="Ganti Avatar"
                app:backgroundTint="@color/accent_orange"
                app:tint="@color/white"
                app:fabSize="normal"
                app:elevation="6dp"
                app:layout_constraintTop_toTopOf="@id/fl_avatar"
                app:layout_constraintBottom_toBottomOf="@id/fl_avatar"
                app:layout_constraintStart_toEndOf="@id/fl_avatar"
                app:layout_constraintEnd_toEndOf="@id/fl_avatar"
                app:layout_constraintVertical_bias="0.9"
                app:layout_constraintHorizontal_bias="0.3" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Card: Nama Anak -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_composite_20_white"
        android:clipToOutline="true"
            android:elevation="0dp"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ubah Nama Panggilan"
                    android:textColor="@color/text_light"
                    android:textSize="12sp"
                    android:fontFamily="@font/lexend"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_nama"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_nama"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Masukkan namamu..."
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/lexend"
                        android:gravity="center"
                        android:inputType="textPersonName"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_simpan_nama"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Simpan Nama"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/lexend"
                    android:layout_marginTop="12dp"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_save_icon"
                    app:iconTint="@color/white"
                    app:iconGravity="textStart"/>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginVertical="16dp"/>

                <!-- Level & XP Area -->
                <TextView
                    android:id="@+id/tv_level_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Penjelajah Pemula"
                    android:textColor="@color/primary_light"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:drawablePadding="8dp"
                    android:drawableTint="@color/primary_light"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <ProgressBar
                        android:id="@+id/pb_xp"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="1"
                        android:progressDrawable="@drawable/custom_progressbar"
                        android:progress="0"
                        android:max="100"/>

                    <TextView
                        android:id="@+id/tv_xp_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 100 XP"
                        android:textSize="11sp"
                        android:textColor="@color/text_light"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>

            </LinearLayout>
        </FrameLayout>

        <!-- Section: Statistik -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Statistik Belajarku"
            android:textColor="@color/primary_light"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="12dp"
            android:drawableStart="@drawable/ic_statistik_belajar"
            android:drawableTint="@color/primary_light"
            android:drawablePadding="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="20dp"
            android:weightSum="3">

            <!-- Stat 1: Total Bintang -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_star_icon"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tv_total_bintang"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_orange"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bintang"
                        android:textSize="11sp"
                        android:textColor="@color/text_light"
                        android:gravity="center"/>
                </LinearLayout>
            </FrameLayout>

            <!-- Stat 2: Kuis Selesai -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_quiz"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tv_kuis_selesai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/success"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kuis Selesai"
                        android:textSize="11sp"
                        android:textColor="@color/text_light"
                        android:gravity="center"/>
                </LinearLayout>
            </FrameLayout>

            <!-- Stat 3: Skor Terbaik -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_trophy"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tv_skor_terbaik"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Skor Terbaik"
                        android:textSize="11sp"
                        android:textColor="@color/text_light"
                        android:gravity="center"/>
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>

        <!-- Section: Lencana -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Koleksi Lencana"
            android:textColor="@color/primary_light"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="12dp"
            android:drawableStart="@drawable/ic_koleksi_lencana"
            android:drawableTint="@color/primary_light"
            android:drawablePadding="8dp"/>

        <!-- Grid Lencana (2x2) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="8dp"
            android:weightSum="2">

            <!-- Badge 1 -->
            <FrameLayout
                android:id="@+id/badge_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    <ImageView android:id="@+id/tv_badge1_icon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_globe"/>
                    <TextView android:id="@+id/tv_badge1_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Penjelajah Pertama"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:layout_marginTop="6dp"/>
                    <TextView android:id="@+id/tv_badge1_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selesaikan 1 kuis"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:textColor="@color/text_light"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </FrameLayout>

            <!-- Badge 2 -->
            <FrameLayout
                android:id="@+id/badge_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    <ImageView android:id="@+id/tv_badge2_icon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_trophy"/>
                    <TextView android:id="@+id/tv_badge2_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sang Juara"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:layout_marginTop="6dp"/>
                    <TextView android:id="@+id/tv_badge2_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Raih skor ≥ 90"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:textColor="@color/text_light"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="8dp"
            android:weightSum="2">

            <!-- Badge 3 -->
            <FrameLayout
                android:id="@+id/badge_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    <ImageView android:id="@+id/tv_badge3_icon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_book_outline"/>
                    <TextView android:id="@+id/tv_badge3_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rajin Belajar"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:layout_marginTop="6dp"/>
                    <TextView android:id="@+id/tv_badge3_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selesaikan 3 kuis"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:textColor="@color/text_light"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </FrameLayout>

            <!-- Badge 4 -->
            <FrameLayout
                android:id="@+id/badge_4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    <ImageView android:id="@+id/tv_badge4_icon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_star_icon"/>
                    <TextView android:id="@+id/tv_badge4_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Maestro Sejarah"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:layout_marginTop="6dp"/>
                    <TextView android:id="@+id/tv_badge4_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selesaikan 5 kuis"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:textColor="@color/text_light"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>

        <!-- Tombol Reset -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:text="Reset Semua Progress"
            app:icon="@drawable/ic_close"
            app:iconGravity="textStart"
            app:iconTint="@color/danger"
            android:textColor="@color/danger"
            android:textSize="13sp"
            app:backgroundTint="#FFF0F0"
            app:strokeColor="@color/danger"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    </LinearLayout>
</ScrollView>
