<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/camera_bg">

    <!-- AR Fragment Base Layer -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/ar_fragment"
        android:name="com.google.ar.sceneform.ux.ArFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Status bar area - translucent -->
    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/overlay_dark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Tombol Kembali (X) - pojok kiri atas, merah, bulat, besar -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginStart="20dp"
        android:src="@drawable/ic_close"
        android:contentDescription="Kembali"
        app:backgroundTint="#DD2222"
        app:tint="@color/white"
        app:fabSize="normal"
        app:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Label "Mode Kamera AR" di atas -->
    <LinearLayout
        android:id="@+id/header_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/badge_bg"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/circle_red"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MODE KAMERA AR"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"/>
    </LinearLayout>



    <!-- Mascot & Chat Bubble Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_panel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_mascot_ar"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/maskot_asmara"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tv_chat_bubble"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Arahkan kamera ke lantai yang datar, lalu ketuk layar untuk memunculkan model 3D."
            android:textColor="@color/text_dark"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_chat_bubble"
            android:padding="16dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintBottom_toBottomOf="@id/iv_mascot_ar"
            app:layout_constraintEnd_toStartOf="@id/iv_mascot_ar"
            app:layout_constraintStart_toStartOf="parent"
            android:elevation="4dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom panel simulasi camera controls -->
    <LinearLayout
        android:id="@+id/bottom_panel"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/overlay_dark"
        android:paddingHorizontal="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Tombol Lanjut Edukasi (Awalnya tersembunyi) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_buka_edukasi"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="BUKA INFO SEJARAH →"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="@color/ar_button"
            app:cornerRadius="15dp"
            android:visibility="gone"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
