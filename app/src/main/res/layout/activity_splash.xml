<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_welcome_gradient">

    <!-- NORMAL STATE (Welcome) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_welcome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">
        
        <!-- Header: Logo + Title -->
        <LinearLayout
            android:id="@+id/ll_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="60dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Frame untuk lingkaran putih -->
            <FrameLayout
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@drawable/circle_white"
                android:elevation="6dp">

                <!-- Logonya kita paksa perbesar (scaleX & scaleY) untuk mengakali ruang kosong bawaan gambarnya -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/logo_asmara"
                    android:scaleType="fitCenter"
                    android:scaleX="1.6"
                    android:scaleY="1.6"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ASMARA"
                android:textColor="@color/white"
                android:textSize="42sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:letterSpacing="0.05"/>
        </LinearLayout>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Augmented Salatiga Monumen &amp;\nArsitektur Reality"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="32dp"
            app:layout_constraintTop_toBottomOf="@id/ll_header"/>

        <!-- Middle: Gedung + Mascot Composition (Native Layout!) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_composition"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
            app:layout_constraintBottom_toTopOf="@id/tv_description">

            <!-- Gedung Papak in background -->
            <ImageView
                android:id="@+id/iv_gedung"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/gedung_papak"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.4"/>

            <!-- Original Mascot overlapping in front -->
            <ImageView
                android:id="@+id/iv_maskot_front"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:src="@drawable/maskot_asmara"
                android:scaleType="fitCenter"
                android:layout_marginBottom="-30dp"
                app:layout_constraintBottom_toBottomOf="@id/iv_gedung"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Description Text -->
        <TextView
            android:id="@+id/tv_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ASMARA menggunakan AR untuk mengenalkan\nbangunan bersejarah yang dikaitkan dengan\nbangun datar dan bangun ruang"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="32dp"
            android:layout_marginHorizontal="24dp"
            app:layout_constraintBottom_toTopOf="@id/btn_mulai"/>

        <!-- Button Mulai Sekarang -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mulai"
            android:layout_width="240dp"
            android:layout_height="64dp"
            android:text="Mulai Sekarang"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="#45C6DB"
            app:cornerRadius="32dp"
            app:elevation="8dp"
            android:layout_marginBottom="48dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- LOADING STATE (Hidden by default) -->
    <LinearLayout
        android:id="@+id/layout_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:background="@drawable/bg_welcome_gradient">

        <!-- New Mascot welcoming -->
        <ImageView
            android:id="@+id/iv_maskot_loading"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:src="@drawable/maskot_welcome"
            android:scaleType="fitCenter"/>

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/white"
            android:layout_marginTop="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Halo! Memuat petualanganmu..."
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
