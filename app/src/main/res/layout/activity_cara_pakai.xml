<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_pattern_tiled">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_cara_pakai"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_glass_header"
        app:titleTextColor="@color/primary_dark"
        app:navigationIconTint="@color/primary_dark"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Panduan Penggunaan ASMARA"
                android:textColor="@color/primary_dark"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ikuti langkah-langkah berikut untuk memulai petualangan belajar geometri!"
                android:textColor="@color/text_medium"
                android:textSize="14sp"
                android:layout_marginBottom="24dp"/>

            <!-- ========== CARA SCAN QR ========== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cara Scan QR Code"
                app:drawableStartCompat="@drawable/ic_camera"
                android:drawablePadding="12dp"
                android:textColor="@color/primary_light"
                android:textSize="17sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Langkah 1 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="1"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/badge_primary"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Buka aplikasi ASMARA, lalu tekan tombol Scan QR di halaman utama."
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:layout_marginStart="16dp"/>
                </LinearLayout>
            </FrameLayout>

            <!-- Langkah 2 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="2"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/badge_primary"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Arahkan kamera HP ke QR Code yang ada di smartcard atau miniatur Gedung Papak."
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:layout_marginStart="16dp"/>
                </LinearLayout>
            </FrameLayout>

            <!-- Langkah 3 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="3"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/badge_primary"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Setelah QR Code berhasil dipindai, aplikasi akan otomatis menampilkan model 3D bangun ruang yang sesuai (Balok, Kubus, Limas, dll)."
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:layout_marginStart="16dp"/>
                </LinearLayout>
            </FrameLayout>

            <!-- ========== CARA LIHAT 3D ========== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cara Melihat Objek 3D"
                app:drawableStartCompat="@drawable/ic_cube"
                android:drawablePadding="12dp"
                android:textColor="@color/primary_light"
                android:textSize="17sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• Geser 1 jari: Putar objek 3D ke segala arah\n\n• Cubit 2 jari: Perbesar atau perkecil objek\n\n• Tekan tombol Lihat Materi: Buka penjelasan lengkap tentang bangun ruang tersebut"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </FrameLayout>

            <!-- Info AR -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_help_outline"
                        app:tint="#2E7D32"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Jika HP kamu mendukung AR, kamu juga bisa melihat objek 3D di dunia nyata melalui mode Petualangan ASMARA!"
                        android:textColor="#2E7D32"
                        android:textSize="13sp"/>
                </LinearLayout>
            </FrameLayout>

            <!-- ========== CARA BUKA MATERI ========== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cara Membuka Materi"
                app:drawableStartCompat="@drawable/ic_book_outline"
                android:drawablePadding="12dp"
                android:textColor="@color/primary_light"
                android:textSize="17sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Setelah model 3D muncul, tekan tombol Lihat Materi di bagian bawah layar. Kamu akan menemukan:\n\n• Pengertian bangun ruang\n• Ciri-ciri / karakteristik\n• Jaring-jaring\n• Contoh dalam kehidupan sehari-hari\n• Audio narasi "
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </FrameLayout>

            <!-- ========== CARA MENGERJAKAN KUIS ========== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cara Mengerjakan Kuis"
                app:drawableStartCompat="@drawable/ic_quiz"
                android:drawablePadding="12dp"
                android:textColor="@color/primary_light"
                android:textSize="17sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. Tekan tombol Kuis di halaman utama\n\n2. Masukkan nama lengkap dan kelas kamu\n\n3. Pilih nomor soal yang ingin dikerjakan (bebas urutan)\n\n4. Baca pertanyaan dan pilih jawaban A, B, atau C\n\n5. Setiap soal memiliki waktu 40 detik\n\n6. Nomor soal yang sudah dijawab akan berubah warna (hijau = benar, merah = salah)\n\n7. Setelah selesai, tekan tombol Selesai untuk melihat hasil\n\n8. Hasil kuis akan otomatis tersimpan di database guru"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </FrameLayout>
            <!-- ========== DOWNLOAD SMARTCARD ========== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Download Kartu Pintar (Smartcard)"
                app:drawableStartCompat="@drawable/ic_save_icon"
                android:drawablePadding="12dp"
                android:textColor="@color/primary_light"
                android:textSize="17sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_composite_16_white"
                android:clipToOutline="true"
                android:elevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Kehilangan buku atau kartu AR fisikmu? Jangan khawatir, kamu bisa mendownload versi PDF-nya di sini lalu mencetaknya sendiri di rumah!"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:textAlignment="center"
                        android:layout_marginBottom="16dp"/>
                        
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_download_smartcard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Download PDF"
                        app:icon="@drawable/ic_book_outline"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="12dp"
                        app:cornerRadius="12dp"/>
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
