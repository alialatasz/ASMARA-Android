<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_pattern_tiled">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_koleksi"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_glass_header"
        app:titleTextColor="@color/primary_dark"
        app:navigationIconTint="@color/primary_dark"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sejarah Kota Salatiga"
                android:textColor="@color/primary_dark"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- Card 1: Gedung Papak -->
            <FrameLayout
                android:id="@+id/card_papak"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_composite_16_white"
                android:clipToOutline="true"
                android:elevation="0dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:src="@drawable/img_papak"
                        android:scaleType="centerCrop"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gedung Papak"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_dark"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Abad ke-19 · Kolonial Belanda"
                            android:textSize="12sp"
                            android:textColor="@color/accent_orange"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Klik untuk membaca sejarah Gedung Papak..."
                            android:textColor="@color/text_medium"
                            android:textSize="14sp"
                            android:lineSpacingExtra="3dp"/>

                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- Card 2: Gedung Pakuwon -->
            <FrameLayout
                android:id="@+id/card_pakuwon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_composite_16_white"
                android:clipToOutline="true"
                android:elevation="0dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:src="@drawable/img_pakuwon"
                        android:scaleType="centerCrop"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gedung Pakuwon"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_dark"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Abad ke-18 · Perjanjian Salatiga"
                            android:textSize="12sp"
                            android:textColor="@color/accent_orange"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Klik untuk membaca sejarah Gedung Pakuwon..."
                            android:textColor="@color/text_medium"
                            android:textSize="14sp"
                            android:lineSpacingExtra="3dp"/>

                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- Card 3: Rumah Dinas -->
            <FrameLayout
                android:id="@+id/card_rumah_dinas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_composite_16_white"
                android:clipToOutline="true"
                android:elevation="0dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:src="@drawable/img_rumah_dinas"
                        android:scaleType="centerCrop"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rumah Dinas Wali Kota"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_dark"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pertengahan Abad ke-19 · GPIB"
                            android:textSize="12sp"
                            android:textColor="@color/accent_orange"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Klik untuk membaca sejarah Rumah Dinas..."
                            android:textColor="@color/text_medium"
                            android:textSize="14sp"
                            android:lineSpacingExtra="3dp"/>

                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
