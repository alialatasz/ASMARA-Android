<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_pattern_tiled">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_koleksi"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_glass_header"
        app:titleTextColor="@color/primary_dark"
        app:navigationIconTint="@color/primary_dark"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Koleksi Bangunan Bersejarah"
                android:textColor="@color/primary_dark"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- Card 1: Gedung Papak -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:src="@drawable/gedung_papak"
                        android:scaleType="centerCrop"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gedung Papak"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Abad ke-19 · Kolonial Belanda"
                            android:textSize="12sp"
                            android:textColor="@color/accent_orange"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Salah satu bangunan bersejarah di Salatiga dengan arsitektur kolonial khas Eropa dan atap datar yang ikonik."
                            android:textColor="@color/text_medium"
                            android:textSize="14sp"
                            android:lineSpacingExtra="3dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✅ Tersedia AR"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/tag_bg_orange"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="5dp"
                            android:layout_marginTop="12dp"/>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- Card 2: Balai Kota -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Placeholder Image (Gradient) -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:background="#D1D9E6"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Balai Kota Salatiga"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Abad ke-20 · Arsitektur Tropis"
                            android:textSize="12sp"
                            android:textColor="@color/text_light"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Pusat pemerintahan Kota Salatiga yang menjadi saksi perjalanan sejarah kota ini dari masa ke masa."
                            android:textColor="@color/text_medium"
                            android:textSize="14sp"
                            android:lineSpacingExtra="3dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔒 Segera Hadir"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/tag_bg_blue"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="5dp"
                            android:layout_marginTop="12dp"/>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- Card 3: Gereja Katedral -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_composite_16_white"
        android:clipToOutline="true"
                android:elevation="0dp"
        >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Placeholder Image (Gradient) -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:background="#D1D9E6"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gereja Katedral Salatiga"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1891 · Neo-Gotik"
                            android:textSize="12sp"
                            android:textColor="@color/text_light"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Gereja bersejarah bergaya neo-gotik yang menjadi salah satu landmark religi dan budaya Kota Salatiga."
                            android:textColor="@color/text_medium"
                            android:textSize="14sp"
                            android:lineSpacingExtra="3dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔒 Segera Hadir"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/tag_bg_blue"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="5dp"
                            android:layout_marginTop="12dp"/>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
