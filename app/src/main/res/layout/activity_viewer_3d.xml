<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fitsSystemWindows="true">

    <!-- Latar belakang gradasi gelap premium -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_viewer_3d"/>

    <!-- SceneView untuk menampilkan model 3D tanpa kamera -->
    <com.google.ar.sceneform.SceneView
        android:id="@+id/scene_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Header Bar -->
    <LinearLayout
        android:id="@+id/header_bar_viewer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:elevation="20dp"
        android:background="#99000000">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_back_viewer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_arrow_back"
            app:fabSize="mini"
            app:backgroundTint="@color/white"
            app:tint="@color/primary_dark"
            android:layout_marginEnd="16dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🖥️  Mode Layar 3D"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Putar dan perbesar dengan jari!"
                android:textColor="#B0BEC5"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Bubble petunjuk di bawah -->
    <LinearLayout
        android:id="@+id/bottom_bar_viewer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:elevation="20dp"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_info_viewer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✨ Sentuh dan geser untuk memutar gedung. Cubit untuk memperbesar!"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:background="@drawable/bg_chat_bubble"
            android:padding="16dp"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_edukasi_viewer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📖  Baca Info Sejarah"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="#00BFA5"
            app:cornerRadius="16dp"
            android:layout_marginBottom="16dp"/>
    </LinearLayout>

</RelativeLayout>
