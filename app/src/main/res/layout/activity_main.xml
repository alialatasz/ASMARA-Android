<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_watermark">

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
    android:background="@drawable/bg_pattern_tiled">

            <!-- Header (Small) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:background="@drawable/bg_glass_header"
                android:gravity="center_vertical">

                <FrameLayout
                    android:id="@+id/fl_header_avatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/circle_white"
                    android:elevation="4dp"
                    android:clipToOutline="true">

                    <TextView
                        android:id="@+id/tv_header_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="🦊"
                        android:textSize="28sp"
                        android:gravity="center" />

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_header_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner.Size50Percent" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_header_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ASMARA"
                        android:textColor="@color/primary_dark"
                        android:textSize="20sp"
                        android:fontFamily="@font/lexend"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Augmented Salatiga Monumen\n&amp; Arsitektur Reality"
                        android:textColor="@color/primary_dark"
                        android:textSize="10sp"
                        android:lineSpacingExtra="2dp"/>
                </LinearLayout>

                <!-- Tombol Toggle Notifikasi -->
                <ImageView
                    android:id="@+id/btn_notif_toggle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_notif_off"
                    android:padding="6dp"
                    android:background="@drawable/circle_white"
                    android:contentDescription="Toggle Notifikasi"/>

            </LinearLayout>

            <!-- Main Content Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Hero Banner -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:elevation="0dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Melengkung Custom Text -->
                        <com.asmara.app.CurvedTextView
                            android:id="@+id/tv_selamat_datang"
                            android:layout_width="match_parent"
                            android:layout_height="160dp"
                            app:layout_constraintTop_toTopOf="parent"
                            android:layout_marginTop="5dp" />

                        <!-- The Gedung Papak Image -->
                        <ImageView
                            android:id="@+id/iv_gedung_papak"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:src="@drawable/gedung_papak"
                            android:scaleType="fitCenter"
                            app:layout_constraintTop_toBottomOf="@+id/tv_selamat_datang"
                            android:layout_marginTop="-40dp" />

                        <!-- Mascot (Enlarged and only element left on top of the image) -->
                        <ImageView
                            android:id="@+id/iv_maskot"
                            android:layout_width="150dp"
                            android:layout_height="150dp"
                            android:src="@drawable/maskot_asmara"
                            android:layout_marginEnd="16dp"
                            android:layout_marginBottom="8dp"
                            app:layout_constraintBottom_toBottomOf="@+id/iv_gedung_papak"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:elevation="2dp"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </FrameLayout>


                <!-- ======================================== -->
                <!-- 6 MENU UTAMA (Grid 2x3) -->
                <!-- ======================================== -->

                <!-- Baris 1: Petualangan ASMARA + Materi -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="12dp">

                    <!-- Tombol 1: Petualangan ASMARA -->
                    <com.asmara.app.BlurGlassView
                        android:id="@+id/btn_petualangan"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:glassColor="#CFECF3"
                        app:glassCornerRadius="24dp"
                        app:blurRadius="20"
                        app:glassAlpha="0.55">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="6dp">

                            <ImageView
                                android:layout_width="140dp"
                                android:layout_height="140dp"
                                android:src="@drawable/ic_adventure"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Petualangan"
                                android:textColor="@color/text_dark"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginTop="10dp"
                                android:gravity="center"/>
                        </LinearLayout>
                    </com.asmara.app.BlurGlassView>

                    <!-- Tombol 2: Materi -->
                    <com.asmara.app.BlurGlassView
                        android:id="@+id/btn_materi"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:glassColor="#F7E49B"
                        app:glassCornerRadius="24dp"
                        app:blurRadius="20"
                        app:glassAlpha="0.55">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="6dp">

                            <ImageView
                                android:layout_width="140dp"
                                android:layout_height="140dp"
                                android:src="@drawable/ic_book_outline" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Materi"
                                android:textColor="@color/text_dark"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginTop="10dp"
                                android:gravity="center"/>
                        </LinearLayout>
                    </com.asmara.app.BlurGlassView>

                </LinearLayout>

                <!-- Baris 2: Scan QR + Kuis -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="12dp">

                    <!-- Tombol 3: Scan QR -->
                    <com.asmara.app.BlurGlassView
                        android:id="@+id/btn_scan_qr"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:glassColor="#FDACAC"
                        app:glassCornerRadius="24dp"
                        app:blurRadius="20"
                        app:glassAlpha="0.55">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="6dp">

                            <ImageView
                                android:layout_width="140dp"
                                android:layout_height="140dp"
                                android:src="@drawable/ic_qr_scan"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Scan QR"
                                android:textColor="@color/text_dark"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginTop="10dp"
                                android:gravity="center"/>
                        </LinearLayout>
                    </com.asmara.app.BlurGlassView>

                    <!-- Tombol 4: Kuis -->
                    <com.asmara.app.BlurGlassView
                        android:id="@+id/btn_kuis"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:glassColor="#CFECF3"
                        app:glassCornerRadius="24dp"
                        app:blurRadius="20"
                        app:glassAlpha="0.55">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="6dp">

                            <ImageView
                                android:layout_width="140dp"
                                android:layout_height="140dp"
                                android:src="@drawable/ic_quiz"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="KUIS"
                                android:textColor="@color/text_dark"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginTop="10dp"
                                android:gravity="center"/>
                        </LinearLayout>
                    </com.asmara.app.BlurGlassView>

                </LinearLayout>

                <!-- Baris 3: Koleksi Sejarah + Panduan Penggunaan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">

                    <!-- Tombol 5: Koleksi Sejarah -->
                    <com.asmara.app.BlurGlassView
                        android:id="@+id/btn_koleksi"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:glassColor="#F7E49B"
                        app:glassCornerRadius="24dp"
                        app:blurRadius="20"
                        app:glassAlpha="0.55">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="6dp">

                            <ImageView
                                android:layout_width="140dp"
                                android:layout_height="140dp"
                                android:src="@drawable/ic_collection" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Koleksi Sejarah"
                                android:textColor="@color/text_dark"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginTop="10dp"
                                android:gravity="center"/>
                        </LinearLayout>
                    </com.asmara.app.BlurGlassView>

                    <!-- Tombol 6: Panduan Penggunaan -->
                    <com.asmara.app.BlurGlassView
                        android:id="@+id/btn_cara_pakai"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:glassColor="#FDACAC"
                        app:glassCornerRadius="24dp"
                        app:blurRadius="20"
                        app:glassAlpha="0.55">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="6dp">

                            <ImageView
                                android:layout_width="140dp"
                                android:layout_height="140dp"
                                android:src="@drawable/ic_guide"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Panduan"
                                android:textColor="@color/text_dark"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginTop="10dp"
                                android:gravity="center"/>
                        </LinearLayout>
                    </com.asmara.app.BlurGlassView>

                </LinearLayout>


            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
