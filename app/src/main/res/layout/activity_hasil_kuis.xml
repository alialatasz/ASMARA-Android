<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_glass_header">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
    android:background="@drawable/bg_pattern_tiled">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KUIS SELESAI!"
                android:textColor="@color/primary_dark"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"
                android:letterSpacing="0.05"/>

            <com.asmara.app.BlurGlassView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:glassColor="#F7E49B"
                app:glassCornerRadius="24dp"
                app:blurRadius="20"
                app:glassAlpha="0.55">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/img_grade_icon"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:src="@drawable/ic_hasil_luar_biasa"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:id="@+id/tv_grade_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LUAR BIASA!"
                        android:textColor="@color/accent_orange"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <!-- Stars -->
                    <LinearLayout
                        android:id="@+id/star_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="24dp">

                        <TextView
                            android:id="@+id/star1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★"
                            android:textColor="@color/white"
                            android:shadowColor="#33000000"
                            android:shadowDx="0"
                            android:shadowDy="4"
                            android:shadowRadius="4"
                            android:textSize="32sp"
                            android:layout_marginHorizontal="4dp"/>
                        <TextView
                            android:id="@+id/star2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★"
                            android:textColor="@color/white"
                            android:shadowColor="#33000000"
                            android:shadowDx="0"
                            android:shadowDy="4"
                            android:shadowRadius="4"
                            android:textSize="60sp"
                            android:layout_marginHorizontal="4dp"/>
                        <TextView
                            android:id="@+id/star3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★"
                            android:textColor="@color/white"
                            android:shadowColor="#33000000"
                            android:shadowDx="0"
                            android:shadowDy="4"
                            android:shadowRadius="4"
                            android:textSize="32sp"
                            android:layout_marginHorizontal="4dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Skor Kamu"
                        android:textColor="@color/accent_orange"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tv_score_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100"
                        android:textColor="@color/accent_orange"
                        android:textSize="48sp"
                        android:textStyle="bold"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="20dp">

                        <TextView
                            android:id="@+id/tv_correct"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✅ 25 Benar"
                            android:textColor="@color/success"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="16dp"/>

                        <TextView
                            android:id="@+id/tv_wrong"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="❌ 0 Salah"
                            android:textColor="@color/danger"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </com.asmara.app.BlurGlassView>

            <com.asmara.app.BlurGlassView
                android:id="@+id/btn_ulangi_kuis"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                app:glassColor="#6FCF97"
                app:glassCornerRadius="32dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="ULANGI KUIS"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center" />
            </com.asmara.app.BlurGlassView>

            <com.asmara.app.BlurGlassView
                android:id="@+id/btn_kembali_home"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                app:glassColor="#56CCF2"
                app:glassCornerRadius="32dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="KEMBALI KE BERANDA"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center" />
            </com.asmara.app.BlurGlassView>

        </LinearLayout>
    </ScrollView>

    <!-- Overlay Konfeti -->
    <com.asmara.app.ConfettiView
        android:id="@+id/confetti_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="10dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
