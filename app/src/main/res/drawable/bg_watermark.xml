<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Latar Belakang Gradasi Biru Lembut yang Elegan -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#D6EAF8"
                android:centerColor="#EBF5FB"
                android:endColor="#FFFFFF"
                android:type="linear"/>
        </shape>
    </item>

    <!-- Siluet Logo Tunggal di Tengah (Transparansi 15% agar jelas terlihat!) -->
    <item
        android:gravity="center"
        android:width="280dp"
        android:height="280dp"
        android:top="50dp">
        <bitmap
            android:src="@drawable/logo_asmara"
            android:alpha="0.15"
            android:gravity="fill" />
    </item>
</layer-list>
